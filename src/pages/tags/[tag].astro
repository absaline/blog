---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      tags.add(tag);
    }
  }
  return [...tags].map((tag) => ({
    params: { tag },
    props: { tag, posts: posts.filter(p => p.data.tags?.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title="{tag} - 标签 | {SITE_TITLE}" description="标签 {tag} 下的所有文章" />
  </head>
  <body>
    <Header />
    <main>
      <h1>标签: {tag}</h1>
      <p class="count">共 {posts.length} 篇文章</p>
      <ul>
        {posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).map(post => (
          <li class="post-item">
            <a href={`/blog/${post.id}/`}>
              <span class="post-title">{post.data.title}</span>
              <FormattedDate date={post.data.pubDate} />
            </a>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>

<style>
  .count { color: rgb(var(--gray)); margin-bottom: 1.5em; }
  ul { list-style: none; padding: 0; }
  .post-item { margin-bottom: 1em; padding-bottom: 1em; border-bottom: 1px solid rgb(var(--gray-light)); }
  .post-item a { text-decoration: none; display: flex; justify-content: space-between; align-items: baseline; }
  .post-title { font-size: 1.1em; font-weight: 600; color: rgb(var(--black)); }
  .post-item a:hover .post-title { color: var(--accent); }
  @media (max-width: 720px) { .post-item a { flex-direction: column; gap: 0.2em; } }
</style>
